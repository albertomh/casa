{
    "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4
    },
    "html": {
        "experimentalFullSupportEnabled": true,
        "formatter": {
            "enabled": true,
            "indentStyle": "space"
        }
    },
    "linter": {
        "rules": {
            "recommended": true
        }
    }
}
